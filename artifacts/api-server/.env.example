# External production PostgreSQL database (existing data — never destroy/reset).
DB_HOST=98.70.11.123
DB_PORT=5433
DB_NAME=tracreone
DB_USER=admin
DB_PASSWORD=password@Secret#2191

# Redis, used for BullMQ background job queues (notifications, follow-up reminders).
REDIS_URL=redis://localhost:6380

# Used to derive JWT access/refresh signing secrets. Keep this secret and stable —
# rotating it invalidates all existing sessions.
SESSION_SECRET=randomly-generated-secret-value

# Provided automatically by the Replit workflow / container runtime.
PORT=8080
NODE_ENV=development
